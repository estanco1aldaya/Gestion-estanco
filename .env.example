# Copia este archivo a .env y rellena los valores reales
# En Railway, configura estas variables en Settings > Variables

# Credenciales de Mi Vending (para el scraping)
MIVENDING_USER=tu_usuario_de_mivending
MIVENDING_PASS=tu_contraseña_de_mivending

# Secreto para las sesiones (pon cualquier cadena larga aleatoria)
SESSION_SECRET=cambia_esto_por_algo_seguro_y_largo_123456

# Puerto (Railway lo pone automáticamente, no tocar)
PORT=3000
